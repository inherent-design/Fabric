    pp.shutdown();
    pp.shutdown();
    EXPECT_FALSE(pp.isValid());
}

TEST(PostProcessTest, DefaultThreshold) {
    PostProcess pp;
    EXPECT_FLOAT_EQ(pp.threshold(), 1.0f);
}

TEST(PostProcessTest, SetThreshold) {
