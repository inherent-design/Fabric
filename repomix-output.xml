    Ess gray(0.3f, 0.3f, 0.3f, 0.5f);
    EXPECT_EQ(MaterialSounds::mapEssenceToMaterial(gray), MaterialType::Stone);
}

TEST(MaterialSoundsTest, MapEssenceToMaterialDirt) {
