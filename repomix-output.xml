    InputSource btn = GamepadButtonSource{SDL_GAMEPAD_BUTTON_SOUTH};
    EXPECT_EQ(inputSourceType(btn), InputSourceType::GamepadButton);

    InputSource axis = GamepadAxisSource{SDL_GAMEPAD_AXIS_LEFTX};
