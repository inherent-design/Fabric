    Ess metal(0.5f, 0.5f, 0.5f, 0.9f);
    EXPECT_EQ(MaterialSounds::mapEssenceToMaterial(metal), MaterialType::Metal);
}

TEST(MaterialSoundsTest, MapEssenceToMaterialSand) {
