    wide.materialTag = 0;

    voxelizeSegment(narrow, densityNarrow, essenceNarrow);
    voxelizeSegment(wide, densityWide, essenceWide);

    // Count non-zero voxels in a cross-section at x=5.
    int narrowCount = 0;
    int wideCount = 0;
    for (int dy = -4; dy <= 4; ++dy) {
