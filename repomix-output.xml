    EXPECT_TRUE(hasPatrol);
    EXPECT_TRUE(hasChase);
    EXPECT_TRUE(hasIsPlayerNearby);
    EXPECT_TRUE(hasCanSee);
    EXPECT_TRUE(hasCanHear);
}

