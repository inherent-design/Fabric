[settings]
windows_default_inline_shell_args = "pwsh -NoProfile -NonInteractive -Command"

[tools]
ccache = "latest"
cmake = "latest"
codeql = { version = "latest", bin_path = "codeql", platforms = """
[linux-x64]
asset_pattern = "codeql-linux64.zip"

[macos-arm64]
asset_pattern = "codeql-osx64.zip"

[macos-x64]
asset_pattern = "codeql-osx64.zip"

[windows-x64]
asset_pattern = "codeql-win64.zip"
""" }
ninja = "latest"

[env]
_.path = ["/opt/homebrew/opt/llvm/bin"]
CC = "clang"
CXX = "clang++"
CPPFLAGS = "-I/opt/homebrew/opt/llvm/include"
