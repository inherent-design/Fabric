    auto b = pw.createDynamicBody(sphere.GetPtr(), 2.0f, 5.0f, 0.0f, 1.0f);

    auto constraint = pw.createFixedConstraint(a, b);
    EXPECT_TRUE(constraint.valid());

    for (int i = 0; i < 10; ++i)
        pw.step(1.0f / 60.0f);
