CMAKE_C_COMPILER_LAUNCHER = "ccache"
CMAKE_CXX_COMPILER_LAUNCHER = "ccache"

# Build

[tasks.clean]
description = "Remove build artifacts"
run = "sh tasks/clean.sh"
run_windows = "& .\\tasks\\clean.ps1"

[tasks.build]
alias = ["b", "bd", "build:debug"]
description = "Configure and build (Debug)"
run = "sh tasks/build.sh"
run_windows = "& .\\tasks\\build.ps1"

[tasks."build:release"]
alias = "br"
description = "Configure and build (Release)"
run = "BUILD_PRESET=dev-release sh tasks/build.sh"
run_windows = "$env:BUILD_PRESET='dev-release'; & .\\tasks\\build.ps1"

# Run

[tasks.run]
alias = ["r", "rd", "run:debug"]
description = "Run Recurse (Debug)"
depends = ["build"]
run = "./build/dev-debug/bin/Recurse"

[tasks."run:release"]
alias = "rr"
description = "Run Recurse (Release)"
