    EXPECT_FLOAT_EQ(result.getPosition().z, 15.0f);
    EXPECT_FLOAT_EQ(result.getScale().x, 2.0f);
    EXPECT_FLOAT_EQ(result.getScale().y, 2.0f);
    EXPECT_FLOAT_EQ(result.getScale().z, 2.0f);
