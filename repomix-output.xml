    EXPECT_FLOAT_EQ(pp.intensity(), 1.5f);
}

TEST(PostProcessTest, DefaultExposure) {
    PostProcess pp;
    EXPECT_FLOAT_EQ(pp.exposure(), 1.0f);
}

TEST(PostProcessTest, SetExposure) {
    PostProcess pp;
    pp.setExposure(2.0f);
    EXPECT_FLOAT_EQ(pp.exposure(), 2.0f);
}

