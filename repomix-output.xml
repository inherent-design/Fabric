    timeline.setAutomaticSnapshots(true, 1.0);
    timeline.update(3.0);

    EXPECT_FALSE(timeline.jumpToSnapshot(999));

    EXPECT_TRUE(timeline.jumpToSnapshot(2));
    EXPECT_EQ(timeline.getHistory().size(), 3);

    EXPECT_TRUE(timeline.jumpToSnapshot(0));
