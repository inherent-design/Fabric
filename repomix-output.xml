class ShadowSystemTest : public ::testing::Test {
  protected:
    Camera camera;
    void SetUp() override { camera.setPerspective(60.0f, 16.0f / 9.0f, 0.1f, 1000.0f, true); }
};

TEST_F(ShadowSystemTest, DefaultConfigValues) {
