        {K_SKIN, K_HALF, K_HALF}, // -X
        {K_HALF, K_SKIN, K_HALF}, // +Y
        {K_HALF, K_SKIN, K_HALF}, // -Y
        {K_HALF, K_HALF, K_SKIN}, // +Z
        {K_HALF, K_HALF, K_SKIN}, // -Z
    };
    // Face center offset from voxel center (0.5 unit along face normal)
    const float K_FACE_OFFSET[6][3] = {
