    Ess white(0.95f, 0.95f, 0.95f, 1.0f);
    EXPECT_EQ(MaterialSounds::mapEssenceToMaterial(white), MaterialType::Snow);
}

TEST(MaterialSoundsTest, MapEssenceToMaterialMetal) {
