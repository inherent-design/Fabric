    recorder.advanceFrame(0.033f);

    recorder.stopRecording();

    EXPECT_EQ(recorder.recording().metadata.totalFrames, 2u);
    EXPECT_NEAR(recorder.recording().metadata.totalDuration, 0.049f, 1e-5f);
