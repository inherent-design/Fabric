// -- GPUInfo field assignment --

TEST(PlatformInfoTest, GPUInfoFieldAssignment) {
    PlatformInfo info;
    info.gpu.vendorId = 0x10de;
    info.gpu.deviceId = 0x2684;
    info.gpu.vendorName = "NVIDIA";
