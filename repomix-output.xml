            break;
        case Rml::Log::LT_INFO:
            FABRIC_LOG_INFO("[RmlUi] {}", message);
            break;
        case Rml::Log::LT_DEBUG:
        case Rml::Log::LT_MAX:
        case Rml::Log::LT_ALWAYS:
