    Ess brown(0.6f, 0.3f, 0.1f, 1.0f);
    EXPECT_EQ(MaterialSounds::mapEssenceToMaterial(brown), MaterialType::Dirt);
}

TEST(MaterialSoundsTest, MapEssenceToMaterialWater) {
    // Blue-dominant: b > 0.6, b > r, b > g
