run = "./build/dev-release/bin/Recurse"

# Lint & Format

[tasks.format]
alias = "fmt"
description = "Check clang-format on source files"
run = "sh tasks/format.sh"
run_windows = "& .\\tasks\\format.ps1"

[tasks."format:fix"]
description = "Auto-format source files"
