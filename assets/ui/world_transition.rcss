body {
    width: 100%;
    height: 100%;
    font-family: "Commit Mono";
    background-color: #04060a;
}

#world-transition-root {
    width: 100%;
    height: 100%;
    background-color: #04060a;
    display: flex;
    align-items: center;
    justify-content: center;
}

#world-transition-card {
    width: 460dp;
    padding: 28dp 32dp;
    background-color: #0c1018;
    border: 1dp rgba(255, 255, 255, 0.12);
    display: flex;
    flex-direction: column;
    gap: 10dp;
}

.transition-title {
    color: #f5f7fa;
    font-size: 28dp;
}

.transition-stage {
    color: #8fd4ff;
    font-size: 16dp;
}

.transition-detail {
    color: #c7d0da;
    font-size: 12dp;
}