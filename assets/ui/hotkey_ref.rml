<rml>
<head>
    <link type="text/rcss" href="hotkey_ref.rcss" />
</head>
<body data-model="hotkeys">
<div id="hotkey-panel">
    <div class="hk-title">Controls <span class="hk-mode">[{{ mode_name }}]</span></div>
    <!-- Hotkey entries are dynamically added by HotkeyPanel::rebuildHotkeys() -->
</div>
</body>
</rml>
